# AI brain routing
# Supported: codex, anthropic, openai, ollama
AI_PROVIDER=codex
SLACK_AI_PROVIDER=
TELEGRAM_AI_PROVIDER=

# Codex brain
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_EXTRA_ARGS=

# Anthropic / Claude brain
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-latest

# OpenAI-compatible brain
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Ollama local brain
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:270m

# Optional behavior
BOT_NAME=Vortex
SYSTEM_PROMPT=You are Codex, a concise, useful AI assistant inside Slack and Telegram. Ask one good question only when needed.
MAX_HISTORY_MESSAGES=12
REPLY_IN_THREAD=true
DASHBOARD_PORT=8787

# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_CHANNEL_IDS=
SLACK_ALLOWED_USER_IDS=

# Telegram
TELEGRAM_BOT_TOKEN=123456:abc...
TELEGRAM_ALLOWED_USER_IDS=
